@model GymLedger.Views.Account.Registration.RegisterAccountView

@{
    ViewBag.Title = "Register";
    ViewBag.ShowTitle = false;
}

<div class="d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-sm p-4 login-card">
        <h3 class="text-primary text-center">Register</h3>
        <hr />

        @using (Html.BeginForm("Register", "Account", FormMethod.Post, new { @class = "needs-validation d-flex flex-column align-items-center", novalidate = "true", id = "registerForm" }))
        {
            <div class="mb-3 w-100">
                @Html.LabelFor(model => model.Username, new { @class = "form-label" })
                @Html.TextBoxFor(model => model.Username, new { @class = "form-control", placeholder = "Enter your username", required = "required" })
                @Html.ValidationMessageFor(model => model.Username, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3 w-100">
                @Html.LabelFor(model => model.Password, new { @class = "form-label" })
                @Html.PasswordFor(model => model.Password, new { @class = "form-control", placeholder = "Enter your password", required = "required" })
                @Html.ValidationMessageFor(model => model.Password, "", new { @class = "text-danger" })
            </div>

            <button type="submit" class="btn btn-primary w-100">Register</button>

            <p class="mt-3 text-center">
                Already have an account? <a href="@Url.Action("Login", "Account")">Click here!</a>
            </p>
        }
    </div>
</div>
