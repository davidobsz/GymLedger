@model GymLedger.Views.Profile.MyProfileView

<div class="modal fade" id="modalModal" tabindex="-1" aria-labelledby="modalModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalModalLabel">Account Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p><b>Username:</b> @Model.Username</p>
                <p><b>Date Added:</b> @Model.DateAdded</p>

                <p>Previous 5 Logins:</p>
                <ul>
                    @foreach (var previousLogin in Model.PreviousLogins)
                    {
                        <li>@previousLogin.LoginDate</li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>