
@{
    ViewBag.Title = "Sessions";
}

<div class="container px-0 mt-2">
    <div class="card shadow-sm">
        <div class="card-body">
            <h5 class="card-title text-center mb-3">Options</h5>
            <ul class="list-group">
                <li class="list-group-item">
                    <a href="@Url.Action("Exercises", "Ledger")" class="text-decoration-none"><i class="fa-regular fa-clipboard"></i> View your Exercises</a>
                </li>
                <li class="list-group-item">
                    <a href="@Url.Action("OneRepMax", "Ledger")" class="text-decoration-none"><i class="fa-solid fa-calculator"></i> View your One Rep Maxes</a>
                </li>
            </ul>
        </div>
    </div>
</div>
<div class="container px-0 mt-4">
    <div class="card card-body">
        
        <div class="row">
            <table class="table bootTable"
                   id="sessionTable"
                   data-toggle="table"
                   data-url="@Url.Action("GetSessions", "Ledger")"
                   data-pagination="true"
                   data-search="true"
                   data-click-to-select="true"
                   data-toolbar-align="left"
                   data-show-refresh="true"
                   data-cache="false"
                   data-show-columns="true"
                   data-toolbar="#sessionToolbar"
                   data-mobile-responsive="true"
                   data-page-list="[10, 25, 50, 100, all]"
                   data-side-pagination="client"
                   data-query-params="queryParams"
                   @*           data-sort-name="DisplayOrder"*@
                   data-sort-order="asc"
                   data-unique-id="UniqueId">
                <thead>
                    <tr>
                        <th data-sortable="false" data-visible="false" data-field="UniqueId">UniqueId</th>
                        <th data-sortable="true" data-field="Exercise">Exercise</th>
                        <th data-sortable="true" data-field="DateAsString">Date</th>
                        <th data-sortable="true" data-field="DateAddedAsString">Date Added</th>
                        <th data-sortable="false" data-field="NumOfSets">Number of Sets</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div id="sessionToolbar">
    <button class="btn btn-light" id="addSession"><a><i class="fa-solid fa-plus fa-lg text-primary" data-bs-toggle="tooltip" data-bs-placement="bottom" title="Add a Session"></i></a></button>
    <button class="btn btn-light" id="downloadallSessions" data-bs-toggle="tooltip" data-bs-placement="bottom" title="Download All Sessions as CSV"><a><i class="fa-solid fa-download text-primary"></i></a></button>
</div>

<div id="sessionTableContainer"
     data-url="@Url.Action("GetSessionDetails", "Ledger")">
</div>

<div id="addSessionContainer"
     data-url="@Url.Action("AddSessionPartial", "Ledger")">
</div>

@Html.Hidden("AddSessionUrl", Url.Action("AddSession", "Ledger"))