@model GymLedger.Views.Areas.Ledger.SessionDetailView

<div class="modal fade" id="modalModal" tabindex="-1" aria-labelledby="modalModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalModalLabel">Session Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <small>You are able to edit the exercise below</small>

            @using (Html.BeginForm("EditSession", "Ledger", FormMethod.Post, new { @class = "form-horizontal", role = "form", id = "editSessionForm" }))
            {
                <div class="modal-body">
                    @Html.HiddenFor(m => m.UniqueId)


                    <div class="mb-3">
                        @Html.LabelFor(m => m.Exercise, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.Exercise, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Exercise)
                    </div>

                    <div class="mb-3">
                        @Html.LabelFor(m => m.Date, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.Date, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                        @Html.ValidationMessageFor(m => m.Date)
                    </div>

                    <hr />
                    <h6>Sets</h6>
                    <div id="setsContainer">
                        @for (int i = 0; i < Model.Sets.Count; i++)
                        {
                            <div class="set-entry mb-3">
                                <div class="row">
                                    <div class="col-md-4">
                                        @Html.LabelFor(m => m.Sets[i].SetNumber, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.Sets[i].SetNumber, new { @class = "form-control" })
                                    </div>
                                    <div class="col-md-4">
                                        @Html.LabelFor(m => m.Sets[i].Reps, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.Sets[i].Reps, new { @class = "form-control" })
                                    </div>
                                    <div class="col-md-4">
                                        @Html.LabelFor(m => m.Sets[i].Weight, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.Sets[i].Weight, new { @class = "form-control" })
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <p>Date Added: @Model.DateAdded</p>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            }

            @using (Html.BeginForm("DeleteSession", "Ledger", FormMethod.Post, new { id = "deleteSessionForm" }))
            {
                @Html.HiddenFor(m => m.UniqueId) 
                <div class="modal-footer">
                    <button type="submit" class="btn btn-danger">
                        <i class="fa-solid fa-trash fa-lg"></i> Delete Session
                    </button>
                </div>
            }
        </div>
    </div>
</div>
