@model GymLedger.Views.Areas.Ledger.SessionDetailView

<div class="modal fade" id="sessionDetailModal" tabindex="-1" aria-labelledby="sessionDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content shadow-lg rounded-4 border-0">
            <!-- Modal Header -->
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold" id="sessionDetailModalLabel">Session Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <!-- Modal Body -->
            <div class="modal-body">
                <p class="text-muted mb-3">You can edit the exercise details below.</p>

                @using (Html.BeginForm("EditSession", "Ledger", FormMethod.Post, new { @class = "needs-validation", role = "form", id = "editSessionForm", novalidate = "novalidate" }))
                {
                    @Html.HiddenFor(m => m.UniqueId)

                    <!-- Exercise Name -->
                    <div class="mb-3">
                        @Html.LabelFor(m => m.Exercise, new { @class = "form-label fw-semibold" })
                        @Html.TextBoxFor(m => m.Exercise, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Exercise, "", new { @class = "text-danger small" })
                    </div>

                    <!-- Date Picker -->
                    <div class="mb-3">
                        @Html.LabelFor(m => m.Date, new { @class = "form-label fw-semibold" })
                        @Html.TextBoxFor(m => m.Date, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                        @Html.ValidationMessageFor(m => m.Date, "", new { @class = "text-danger small" })
                    </div>

                    <hr />
                    <h6 class="fw-bold">Sets</h6>
                    <div id="setsContainer">
                        @for (int i = 0; i < Model.Sets.Count; i++)
                        {
                            <div class="set-entry border rounded p-3 mb-3 bg-light position-relative">
                                <div class="row">
                                    <div class="col-md-4">
                                        @Html.LabelFor(m => m.Sets[i].SetNumber, new { @class = "form-label fw-semibold" })
                                        @Html.TextBoxFor(m => m.Sets[i].SetNumber, new { @class = "form-control" })
                                    </div>
                                    <div class="col-md-4">
                                        @Html.LabelFor(m => m.Sets[i].Reps, new { @class = "form-label fw-semibold" })
                                        @Html.TextBoxFor(m => m.Sets[i].Reps, new { @class = "form-control" })
                                    </div>
                                    <div class="col-md-4">
                                        @Html.LabelFor(m => m.Sets[i].Weight, new { @class = "form-label fw-semibold" })
                                        @Html.TextBoxFor(m => m.Sets[i].Weight, new { @class = "form-control" })
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <p class="text-muted">Date Added: @Model.DateAdded</p>

                    <div class="text-end mt-3">
                        <button type="submit" class="btn btn-success px-4">
                            <i class="fa-solid fa-check"></i> Save Changes
                        </button>
                    </div>
                }
            </div>

            <!-- Delete Button -->
            <div class="modal-footer d-flex justify-content-between">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                @using (Html.BeginForm("DeleteSession", "Ledger", FormMethod.Post, new { id = "deleteSessionForm" }))
                {
                    @Html.HiddenFor(m => m.UniqueId)
                    <button type="submit" class="btn btn-danger">
                        <i class="fa-solid fa-trash fa-lg"></i> Delete Session
                    </button>
                }
            </div>
        </div>
    </div>
</div>

