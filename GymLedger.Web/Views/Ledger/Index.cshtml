
@{
    ViewBag.Title = "Ledger";
}

<!-- Container for options for ledger -->
<div class="container px-0 mt-2">
    <div class="card shadow-sm">
        <div class="card-body">
            <h5 class="card-title text-center mb-3">Options</h5>
            <ul class="list-group">
                <li class="list-group-item">
                    <a href="@Url.Action("Exercises", "Ledger")" class="text-decoration-none"><i class="fa-regular fa-clipboard"></i> View your Exercises</a>
                </li>
                <li class="list-group-item">
                    <a href="@Url.Action("Sessions", "Ledger")" class="text-decoration-none"><i class="fa-solid fa-dumbbell"></i> View your Sessions</a>
                </li>
            </ul>
        </div>
    </div>
</div>

<div class="container px-0 mt-3">
    <div class="card card-body">
        <div class="row">
            <!-- Exercises Pie Chart Card -->
            <div class="col-12 col-md-4 pb-3">
                <div class="card shadow-lg rounded-4 border-0">
                    <div class="card-header bg-primary text-white text-center fw-bold">
                        Exercises Pie Chart
                    </div>
                    <div class="card-body d-flex justify-content-center">
                        <canvas id="exercisesPieChart"></canvas>
                    </div>
                    <button class="btn btn-light" id="downloadExercisesPieChart"><a><i class="fa-solid fa-download text-primary"></i></a> Download Image</button>
                    <button class="btn btn-light expand-chart" data-bs-toggle="modal" data-bs-target="#chartModal" data-chart="exercisesPieChart"><i class="fa-solid fa-maximize text-primary"></i> Expand</button>
                    <div class="card-footer bg-light rounded-bottom-4">
                        <div class="mb-3">
                            <label for="startDate" class="fw-semibold">Start Date:</label>
                            <input type="date" id="startDate" class="form-control">
                        </div>
                        <div class="mb-3">
                            <label for="endDate" class="fw-semibold">End Date:</label>
                            <input type="date" id="endDate" class="form-control">
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <button id="runReportExercises" class="btn btn-primary px-4">Run Report</button>
                            <button class="btn btn-outline-secondary p-2" data-bs-toggle="collapse" data-bs-target="#collapseExercisesProgressBarchart" aria-expanded="false">
                                <i class="fa-solid fa-question fa-xs"></i>
                            </button>
                        </div>
                        <div class="collapse mt-3" id="collapseExercisesProgressBarchart">
                            <div class="card card-body bg-white shadow-sm border-0">
                                This graph shows you how many sessions per exercise you have entered.
                            </div>
                        </div>
                    </div>
                </div>
            </div>


            <!-- Sessions Line Chart Card-->
            <div class="col-12 col-md-4 pb-3">
                <div class="card shadow-lg rounded-4 border-0">
                    <div class="card-header bg-primary text-white text-center fw-bold">
                        Sessions Line Chart
                    </div>
                    <div class="card-body d-flex justify-content-center">
                        <canvas id="sessionsLineChart"></canvas>
                    </div>
                    <button class="btn btn-light" id="downloadSessionsLineChart"><a><i class="fa-solid fa-download text-primary"></i></a> Download Image</button>
                    <button class="btn btn-light expand-chart" data-bs-toggle="modal" data-bs-target="#chartModal" data-chart="sessionsLineChart"><i class="fa-solid fa-maximize text-primary"></i> Expand</button>
                    <div class="card-footer bg-light rounded-bottom-4">
                        <div class="mb-3">
                            <label for="startDate2" class="fw-semibold">Start Date:</label>
                            <input type="date" id="startDate2" class="form-control">
                        </div>
                        <div class="mb-3">
                            <label for="endDate2" class="fw-semibold">End Date:</label>
                            <input type="date" id="endDate2" class="form-control">
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <button id="runReportSessions" class="btn btn-primary px-4">Run Report</button>
                            <button class="btn btn-outline-secondary p-2" data-bs-toggle="collapse" data-bs-target="#collapseSessionsProgressBarchart" aria-expanded="false">
                                <i class="fa-solid fa-question fa-xs"></i>
                            </button>
                        </div>
                        <div class="collapse mt-3" id="collapseSessionsProgressBarchart">
                            <div class="card card-body bg-white shadow-sm border-0">
                                This graph shows you the total session volume progress as a % per exercise.
                            </div>
                        </div>
                    </div>
                </div>
            </div>


            <!-- Sets Bar Chart Card-->
            <div class="col-12 col-md-4">
                <div class="card shadow-lg rounded-4 border-0">
                    <div class="card-header bg-primary text-white text-center fw-bold">
                        Sets Bar Chart
                    </div>
                    <div class="card-body d-flex justify-content-center">
                        <canvas id="setsLineChart"></canvas>
                    </div>
                    <button class="btn btn-light" id="downloadSetsBarChart"><a><i class="fa-solid fa-download text-primary"></i></a> Download Image</button>
                    <button class="btn btn-light expand-chart" data-bs-toggle="modal" data-bs-target="#chartModal" data-chart="setsLineChart"><i class="fa-solid fa-maximize text-primary"></i> Expand</button>
                    <div class="card-footer bg-light rounded-bottom-4">
                        <div class="mb-3">
                            <label for="startDate3" class="fw-semibold">Start Date:</label>
                            <input type="date" id="startDate3" class="form-control">
                        </div>
                        <div class="mb-3">
                            <label for="endDate3" class="fw-semibold">End Date:</label>
                            <input type="date" id="endDate3" class="form-control">
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <button id="runReportSets" class="btn btn-primary px-4">Run Report</button>
                            <button class="btn btn-outline-secondary p-2" data-bs-toggle="collapse" data-bs-target="#collapseSetsProgressBarchart" aria-expanded="false">
                                <i class="fa-solid fa-question fa-xs"></i>
                            </button>
                        </div>
                        <div class="collapse mt-3" id="collapseSetsProgressBarchart">
                            <div class="card card-body bg-white shadow-sm border-0">
                                This graph shows you the total sets per exercise.
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Bootstrap Modal -->
<div class="modal fade" id="chartModal" tabindex="-1" aria-labelledby="chartModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content shadow-lg rounded-4 border-0">
            <!-- Modal Header -->
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold" id="chartModalLabel">Expanded Chart</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <!-- Modal Body -->
            <div class="modal-body text-center">
                <canvas id="expandedChart"></canvas>
            </div>
        </div>
    </div>
</div>



<!-- store URL for get exercises LedgerControlerr method -->
<div id="chartDataUrl" data-url="@Url.Action("GetExercisesPiechart", "Ledger")" style="display:none;"></div>
<div id="sessionDataUrl" data-url="@Url.Action("GetSessionsLinechart", "Ledger")" style="display:none;"></div>
<div id="setsDataUrl" data-url="@Url.Action("GetSetsBarchart", "Ledger")" style="display:none;"></div>