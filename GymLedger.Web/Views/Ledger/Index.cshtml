
@{
    ViewBag.Title = "Ledger";
}

<!-- Container for options for ledger -->
<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-body">
            <h5 class="card-title text-center mb-3">Options</h5>
            <ul class="list-group">
                <li class="list-group-item">
                    <a href="@Url.Action("Exercises", "Ledger")" class="text-decoration-none"><i class="fa-regular fa-clipboard"></i> View your Exercises</a>
                </li>
                <li class="list-group-item">
                    <a href="@Url.Action("Sessions", "Ledger")" class="text-decoration-none"><i class="fa-solid fa-dumbbell"></i> View your Sessions</a>
                </li>
            </ul>
        </div>
    </div>
</div>

<div class="container mt-4">
    <div class="row">
        <!-- Exercises Pie Chart Card -->
        <div class="col-12 col-md-4">
            <div class="card">
                <div class="card-header">
                    Exercises Pie Chart
                </div>
                <div class="card-body justify-content-center">
                    <canvas id="exercisesPieChart"></canvas>
                </div>
                <div class="card-footer">
                    <div class="col-md-12 mb-3">
                        <label for="startDate">Start Date:</label>
                        <input type="date" id="startDate" class="form-control">
                    </div>
                    <div class="col-md-12 mb-3">
                        <label for="endDate">End Date:</label>
                        <input type="date" id="endDate" class="form-control">
                    </div>
                    <div class="d-flex justify-content-between col-md-12">
                        <button id="runReportExercises" class="btn btn-primary">Run Report</button>

                        <small class="btn btn-primary" data-bs-toggle="collapse" data-bs-target="#collapseExercisesProgressBarchart" aria-expanded="false" aria-controls="collapseExample">
                            <i class="fa-solid fa-question fa-xs"></i>
                        </small>
                    </div>
                    <div class="collapse" id="collapseExercisesProgressBarchart">
                        <div class="card card-body mt-2">
                            This graph shows you how many sessions per exercise you have entered
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sessions Line Chart Card-->
        <div class="col-12 col-md-4">
            <div class="card">
                <div class="card-header">Sessions Line Chart</div>
                <div class="card-body justify-content-center">
                    <canvas id="sessionsLineChart"></canvas>
                </div>
                <div class="card-footer">
                    <div class="col-md-12 mb-3">
                        <label for="startDate">Start Date:</label>
                        <input type="date" id="startDate2" class="form-control">
                    </div>
                    <div class="col-md-12 mb-3">
                        <label for="endDate">End Date:</label>
                        <input type="date" id="endDate2" class="form-control">
                    </div>
                    <div class="d-flex justify-content-between col-md-12">
                        <button id="runReportSessions" class="btn btn-primary">Run Report</button>

                        <small class="btn btn-primary" data-bs-toggle="collapse" data-bs-target="#collapseSessionsProgressBarchart" aria-expanded="false" aria-controls="collapseExample">
                            <i class="fa-solid fa-question fa-xs"></i>
                        </small>
                    </div>
                    <div class="collapse" id="collapseSessionsProgressBarchart">
                        <div class="card card-body mt-2">
                            This graph shows you the total session volume progress as a % per exercise
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sets Bar Chart Card-->
        <div class="col-12 col-md-4">
            <div class="card">
                <div class="card-header">Sets Bar Chart</div>
                <div class="card-body justify-content-center">
                    <canvas id="setsLineChart"></canvas>
                </div>
                <div class="card-footer">
                    <div class="col-md-12 mb-3">
                        <label for="startDate">Start Date:</label>
                        <input type="date" id="startDate3" class="form-control">
                    </div>
                    <div class="col-md-12 mb-3">
                        <label for="endDate">End Date:</label>
                        <input type="date" id="endDate3" class="form-control">
                    </div>
                    <div class="d-flex justify-content-between col-md-12">
                        <button id="runReportSets" class="btn btn-primary">Run Report</button>


                        <small class="btn btn-primary" data-bs-toggle="collapse" data-bs-target="#collapseSetsProgressBarchart" aria-expanded="false" aria-controls="collapseExample">
                            <i class="fa-solid fa-question fa-xs"></i>
                        </small>
                    </div>
                    <div class="collapse" id="collapseSetsProgressBarchart">
                        <div class="card card-body mt-2">
                            This graph shows you the total sets per exercise
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<!-- store URL for get exercises LedgerControlerr method -->
<div id="chartDataUrl" data-url="@Url.Action("GetExercisesPiechart", "Ledger")" style="display:none;"></div>
<div id="sessionDataUrl" data-url="@Url.Action("GetSessionsLinechart", "Ledger")" style="display:none;"></div>
<div id="setsDataUrl" data-url="@Url.Action("GetSetsBarchart", "Ledger")" style="display:none;"></div>