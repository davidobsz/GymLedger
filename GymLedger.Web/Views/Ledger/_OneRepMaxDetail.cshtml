@model GymLedger.Views.Areas.Ledger.OneRepMaxView


<div class="modal fade" id="oneRepMaxModal" tabindex="-1" aria-labelledby="oneRepMaxModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content shadow-lg rounded-4 border-0">
            <!-- Modal Header -->
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold" id="oneRepMaxModalLabel">One Rep Max Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <!-- Modal Body -->
            <div class="modal-body">
                <p class="text-muted mb-3">You are able to edit the one rep max below.</p>

                @using (Html.BeginForm("EditOneRepMax", "Ledger", FormMethod.Post, new { @class = "needs-validation", role = "form", id = "editOneRepMaxForm", novalidate = "novalidate" }))
                {
                    @Html.HiddenFor(m => m.UniqueId)

                    <div class="mb-3">
                        @Html.LabelFor(m => m.Exercise, new { @class = "form-label fw-semibold" })
                        @Html.TextBoxFor(m => m.Exercise, new { @class = "form-control", placeholder = Model.Exercise })
                        @Html.ValidationMessageFor(m => m.Exercise, "", new { @class = "text-danger small" })
                    </div>

                    <div class="mb-3">
                        @Html.LabelFor(m => m.Weight, new { @class = "form-label fw-semibold" })
                        @Html.TextBoxFor(m => m.Weight, new { @class = "form-control", placeholder = Model.Weight.ToString("F1") })
                        @Html.ValidationMessageFor(m => m.Weight, "", new { @class = "text-danger small" })
                    </div>

                    <div class="mb-3">
                        @Html.LabelFor(m => m.DateAdded, new { @class = "form-label fw-semibold" })
                        @Html.TextBoxFor(m => m.DateAdded, new { @class = "form-control", type = "date", Value = Model.DateAddedAsString })
                        @Html.ValidationMessageFor(m => m.DateAdded, "", new { @class = "text-danger small" })
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-success px-4">
                            <i class="fa-solid fa-check"></i> Save Changes
                        </button>
                    </div>
                }
            </div>

            <!-- Delete Exercise -->
            @using (Html.BeginForm("DeleteOneRepMax", "Ledger", FormMethod.Post, new { id = "deleteOneRepMaxForm" }))
            {
                @Html.HiddenFor(m => m.UniqueId)
                <div class="modal-footer">
                    <button type="submit" class="btn btn-danger">
                        <i class="fa-solid fa-trash fa-lg"></i> Delete One Rep Max
                    </button>
                </div>
            }
        </div>
    </div>
</div>