@model GymLedger.Views.Areas.Ledger.AddSessionView

<div class="modal fade" id="sessionModal" tabindex="-1" aria-labelledby="sessionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content shadow-lg rounded-4 border-0">
            <!-- Modal Header -->
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold" id="sessionModalLabel">Add Session</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <!-- Modal Body -->
            <div class="modal-body">
                <p class="text-muted mb-3">Fill in the details below to add a new session.</p>

                @using (Html.BeginForm("AddSession", "Ledger", FormMethod.Post, new { @class = "needs-validation", role = "form", id = "addSessionForm", novalidate = "novalidate" }))
                {
                    @Html.AntiForgeryToken()

                    <!-- Exercise Selection -->
                    <div class="mb-3">
                        @Html.LabelFor(m => m.Exercises, new { @class = "form-label fw-semibold" })
                        @Html.DropDownListFor(m => m.ExerciseName, new SelectList(Model.Exercises, "Name", "Name"), "Select Exercise", new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Exercises, "", new { @class = "text-danger small" })
                    </div>

                    <!-- Date Picker -->
                    <div class="mb-3">
                        @Html.LabelFor(m => m.Date, new { @class = "form-label fw-semibold" })
                        <input type="date" class="form-control" name="Date" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>

                    <!-- Add Set Button -->
                    <button type="button" class="btn btn-outline-primary w-100 mb-3" id="add-set">
                        <i class="fa-solid fa-plus"></i> Add Set
                    </button>

                    <!-- Sets Container -->
                    <div id="sets-container"></div>

                    <!-- Save Button -->
                    <div class="text-end mt-3">
                        <button type="submit" class="btn btn-success px-4">
                            <i class="fa-solid fa-check"></i> Save Session
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Hidden Template for Adding Sets -->
<div id="set-template" class="d-none">
    <div class="set-entry border rounded p-3 mb-3 bg-light position-relative">
        <div class="row">
            <div class="col-md-4 mb-2">
                <label for="SetNumber" class="form-label fw-semibold">Set #</label>
                <input type="number" name="Sets[0].SetNumber" class="form-control" />
            </div>
            <div class="col-md-4 mb-2">
                <label for="Weight" class="form-label fw-semibold">Weight (kg/lbs)</label>
                <input type="number" name="Sets[0].Weight" class="form-control" />
            </div>
            <div class="col-md-4 mb-2">
                <label for="Reps" class="form-label fw-semibold">Reps</label>
                <input type="number" name="Sets[0].Reps" class="form-control" />
            </div>
        </div>
        <button type="button" class="btn btn-danger btn-sm position-absolute top-0 end-0 m-2 remove-set">
            <i class="fa-solid fa-trash"></i>
        </button>
    </div>
</div>
