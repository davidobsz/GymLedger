@model GymLedger.Views.Areas.Ledger.CalculateOneRepMaxView
@{
    ViewBag.Title = "One Rep Maxes";
}
<div class="container px-0 mt-2">
    <div class="card shadow-sm">
        <div class="card-body">
            <h5 class="card-title text-center mb-3">Options</h5>
            <ul class="list-group">
                <li class="list-group-item">
                    <a href="@Url.Action("Exercises", "Ledger")" class="text-decoration-none"><i class="fa-regular fa-clipboard"></i> View your Exercises</a>
                </li>
                <li class="list-group-item">
                    <a href="@Url.Action("Sessions", "Ledger")" class="text-decoration-none"><i class="fa-solid fa-dumbbell"></i> View your Sessions</a>
                </li>
            </ul>
        </div>
    </div>
</div>

<div class="container px-0 mt-2">
    <div class="card shadow-sm">
        <div class="card-body p-3">
            <h5 class="card-title text-center mb-3">Calculate One Rep Max</h5>

            <p class="text-muted mb-3">Calculate your one rep max using the form below.</p>

            @using (Html.BeginForm("CalculateOneRepMax", "Ledger", FormMethod.Post, new { @class = "needs-validation", role = "form", id = "calculateOneRepMaxForm", novalidate = "novalidate" }))
            {
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    @Html.LabelFor(m => m.Weight, new { @class = "form-label fw-semibold" })
                    @Html.TextBoxFor(m => m.Weight, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Weight, "", new { @class = "text-danger small" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.Reps, new { @class = "form-label fw-semibold" })
                    @Html.TextBoxFor(m => m.Reps, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Reps, "", new { @class = "text-danger small" })
                </div>

                <div id="oneRepMaxResult">

                </div>

                <div class="text-end mt-3">
                    <button type="submit" class="btn btn-success px-4">
                        <i class="fa-solid fa-check"></i> Submit
                    </button>
                </div>
            }
        </div>
    </div>
</div>

<div class="container px-0 mt-2">
    <div class="card card-body">

        <div class="row">
            <table class="table bootTable"
                   id="OneRepMaxesTable"
                   data-toggle="table"
                   data-url="@Url.Action("GetOneRepMaxes", "Ledger")"
                   data-pagination="true"
                   data-search="true"
                   data-click-to-select="true"
                   data-toolbar-align="left"
                   data-show-refresh="true"
                   data-cache="false"
                   data-show-columns="true"
                   data-toolbar="#sessionToolbar"
                   data-mobile-responsive="true"
                   data-page-list="[10, 25, 50, 100, all]"
                   data-side-pagination="client"
                   data-query-params="queryParams"
                   @*           data-sort-name="DisplayOrder"*@
                   data-sort-order="asc"
                   data-unique-id="UniqueId">
                <thead>
                    <tr>
                        <th data-sortable="false" data-visible="false" data-field="UniqueId">UniqueId</th>
                        <th data-sortable="true" data-field="Exercise">Exercise</th>
                        <th data-sortable="true" data-field="DateAsString">Date</th>
                        <th data-sortable="true" data-field="Weight">Weight</th>
                        <th data-sortable="true" data-field="DateAddedAsString">Date Added</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div id="sessionToolbar">
    <button class="btn btn-light" id="addOneRepMax"><a><i class="fa-solid fa-plus fa-lg text-primary" data-bs-toggle="tooltip" data-bs-placement="bottom" title="Add a One Rep Max"></i></a></button>
    <button class="btn btn-light" id="downloadallOneRepMaxes" data-bs-toggle="tooltip" data-bs-placement="bottom" title="Download All One Rep Maxes as CSV"><a><i class="fa-solid fa-download text-primary"></i></a></button>
</div>

<div id="oneRepMaxTableContainer"
     data-url="@Url.Action("GetOneRepMaxDetails", "Ledger")">
</div>

<div id="addOneRepMaxContainer"
     data-url="@Url.Action("AddOneRepMaxPartial", "Ledger")">
</div>

@Html.Hidden("AddSessionUrl", Url.Action("AddOneRepMax", "Ledger"))

